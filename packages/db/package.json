{
	"name": "@repo/db",
	"version": "0.0.1",
	"description": "Framework-agnostic Drizzle ORM database package with schema definitions and database client.",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		"./schema": {
			"types": "./src/schema.ts",
			"default": "./dist/schema.js"
		},
		"./client": {
			"types": "./src/client.ts",
			"default": "./dist/client.js"
		},
		"./enb-backup/schema": {
			"types": "./src/enb-backup/schema.ts",
			"default": "./dist/enb-backup/schema.js"
		},
		"./enb-backup/client": {
			"types": "./src/enb-backup/client.ts",
			"default": "./dist/enb-backup/client.js"
		}
	},
	"typesVersions": {
		"*": {
			"schema": [
				"./src/schema.ts"
			],
			"client": [
				"./src/client.ts"
			],
			"enb-backup/schema": [
				"./src/enb-backup/schema.ts"
			],
			"enb-backup/client": [
				"./src/enb-backup/client.ts"
			]
		}
	},
	"scripts": {
		"clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('.cache/tsbuildinfo.json',{force:true})\"",
		"build": "pnpm clean && tsc",
		"dev": "tsc --watch",
		"format": "prettier --write \"src/**/*.ts\"",
		"lint": "eslint --flag unstable_native_nodejs_ts_config . --fix",
		"typecheck": "tsc --noEmit",
		"push": "pnpm build && drizzle-kit push",
		"studio": "pnpm build && drizzle-kit studio",
		"generate": "pnpm build && drizzle-kit generate",
		"migrate": "pnpm build && drizzle-kit migrate",
		"push:enb-backup": "pnpm build && drizzle-kit push --config drizzle.enb-backup.config.ts",
		"seed": "pnpm push && tsx src/seed.ts",
		"seed:exam": "tsx src/seed-exam-content.ts",
		"reconcile:enb-backup": "tsx scripts/reconcile-enb-backup.ts"
	},
	"dependencies": {
		"better-auth": "catalog:",
		"drizzle-orm": "catalog:",
		"pg": "catalog:"
	},
	"devDependencies": {
		"@repo/eslint-config": "workspace:*",
		"@repo/prettier-config": "workspace:*",
		"@repo/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"@types/pg": "catalog:",
		"dotenv": "catalog:",
		"drizzle-kit": "1.0.0-beta.9-e89174b",
		"eslint": "catalog:",
		"prettier": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	},
	"prettier": "@repo/prettier-config"
}
