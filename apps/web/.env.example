# ==========================================================
# WEB APP ENVIRONMENT VARIABLES
# ==========================================================

# Server Configuration
NODE_ENV=development

# Server-only internal API URL (optional, useful in Docker/container networks)
# INTERNAL_API_BASE_URL=http://backend:3000/api

NEXT_PUBLIC_TERMS_URL=https://your-terms-url.com
NEXT_PUBLIC_PRIVACY_URL=https://your-privacy-url.com

# Public URLs
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Same origin as the web app; Next.js dev server proxies /api → Nest (see next.config.ts).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
# Nest URL for Next.js dev rewrites (must match apps/backend PORT)
BACKEND_PROXY_ORIGIN=http://localhost:3080
# Optional: show "Complete exam" on staging/production builds (requires rebuild after change)
# NEXT_PUBLIC_CERT_EXAM_DEV_ASSIST=true

NEXT_PUBLIC_API_VERSION=v1
# Optional Socket.IO origin (no path). Leave unset in dev to use the web app origin + Next `/socket.io` proxy.
# NEXT_PUBLIC_WS_ORIGIN=https://api.example.com

# Google Maps — appointment lobby Static Map + Geocoding (browser). Copy from root GOOGLE_MAPS_API_KEY if needed.
# Enable Maps Static API + Geocoding API on the same key/restrictions where appropriate.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# When "true", the lobby LocationErrorDialog renders technical details (requestId, status codes, etc.).
# Mirrors the backend LOCATION_VERIFICATION_DEBUG flag for parity in support sessions.
# NEXT_PUBLIC_LOCATION_VERIFICATION_DEBUG=false

# Max browser-reported GPS accuracy (metres) accepted by the session lobby UI gate.
# Keep this aligned with backend SESSION_GPS_MAX_ACCURACY_M.
NEXT_PUBLIC_SESSION_GPS_MAX_ACCURACY_M=200

# Staff-only password to unlock “Advanced / manual completion” on ENP onboarding (server-only).
# ONBOARDING_MANUAL_UNLOCK_PASSWORD=

# Emergency maintenance-mode kill switch (server-only). When "true", middleware locks
# non-admins to /maintenance regardless of the DB flag. Toggle the DB flag from /admin/settings.
# MAINTENANCE_MODE=false

# QLearn LMS integration (ENP onboarding) — API keys live in apps/backend/.env only
# NEXT_PUBLIC_ENABLE_LMS_INTEGRATION=true
# See docs/integrations/qlearn-qlegal-overview.md
