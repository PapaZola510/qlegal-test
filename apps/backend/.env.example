# ==========================================================
# BACKEND API ENVIRONMENT VARIABLES
# ==========================================================

# Server Configuration
NODE_ENV=development
PORT=3080
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Emergency maintenance-mode kill switch. When "true", the API returns 503 for all
# non-admin routes (mobile included), regardless of the DB flag. Toggle the DB flag
# from the web admin at /admin/settings.
MAINTENANCE_MODE=false

# Database
DATABASE_URL="postgres://postgres:password@localhost:5432/turbo-template"
# Separate PostgreSQL for Electronic Notarial Book backup (run: pnpm --filter @repo/db push:enb-backup)
ENB_BACKUP_DATABASE_URL="postgres://postgres:password@localhost:5432/qlegal-enb-backup"

# Authentication (Better Auth)
BETTER_AUTH_SECRET=default-secret-for-testing-change-in-production
# Required for OAuth: public browser origin (Next :3001). Without this, Better Auth uses Nest :3000 for redirect_uri while state cookies live on :3001 → state_not_found.
BETTER_AUTH_URL=http://localhost:3001
# Links in QuickSign invite emails (defaults to BETTER_AUTH_URL)
# PUBLIC_APP_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3000
BETTER_AUTH_COOKIE_DOMAIN=localhost

# OAuth Providers (Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


NEXT_PUBLIC_TERMS_URL=https://privacy.gov.ph/data-privacy-act/
NEXT_PUBLIC_PRIVACY_URL=https://privacy.gov.ph/data-privacy-act/

# S3-compatible storage (Supabase Storage — S3 API). Optional in development (in-memory adapter).
# S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true

# Hyperverge (ENP identity / KYC). Webhook path: POST /api/v1/onboarding/hyperverge/webhook
# HYPERVERGE_APP_ID=
# HYPERVERGE_APP_KEY=
# IDV base for Web SDK POST /v2/auth/token (defaults to https://ind.idv.hyperverge.co if unset or non-idv URL)
# IDV API host (link-kyc, output, logs, SDK token). Do NOT use auth.hyperverge.co here.
# HYPERVERGE_API_URL=https://ind.idv.hyperverge.co
# HYPERVERGE_AUTH_BASE_URL=https://auth.hyperverge.co
# HYPERVERGE_WORKFLOW_ID=workflow_onboarding
# HYPERVERGE_LIVENESS_WORKFLOW_ID=workflow_liveness
# HYPERVERGE_WEB_SDK_VERSION=10.3.0
# HYPERVERGE_WEBHOOK_SECRET=change-me
# HYPERVERGE_WEBHOOK_SIGNATURE_HEADER=x-hyperverge-signature
# ENP identity re-verification window after successful verification (days), same semantics as quanby-legal
# KYC_VERIFICATION_VALIDITY_DAYS=14

# Payments (exam retake, etc.). Webhook: POST /api/v1/payments/gateway/webhook — body JSON { "intentId": "...", "status": "succeeded"|"failed" }, header x-qlegal-payment-signature = hex HMAC-SHA256(rawBody, PAYMENT_WEBHOOK_SECRET)
# PAYMENT_WEBHOOK_SECRET=

# Compliance audit exports (required in production): HMAC key for signed manifests.
# COMPLIANCE_EXPORT_SIGNING_KEY=

# HitPay (meeting session QRPH). Docs: https://docs.hitpayapp.com/introduction
# Sandbox API: https://api.sandbox.hit-pay.com  Production API: https://api.hit-pay.com (client appends /v1)
# Register webhook in HitPay Dashboard → Developers → Webhook Endpoints:
#   URL: https://<your-api-host>/api/v1/payments/hitpay/webhook
#   Event: payment_request.completed
#   Signature: Hitpay-Signature header = HMAC-SHA256(raw JSON body, HITPAY_WEBHOOK_SALT)
# HITPAY_API_KEY=
# HITPAY_API_URL=https://api.sandbox.hit-pay.com
# HITPAY_WEBHOOK_SALT=
# Meeting session fee breakdown (notarial subtotal + convenience + processing + VAT = client total)
# MEETING_CONVENIENCE_FEE_BPS=500
# MEETING_VAT_BPS=1200
# MEETING_HITPAY_QRPH_FEE_BPS=100
# MEETING_HITPAY_QRPH_FEE_MIN_PHP=20

# Meeting session payments: hitpay (sandbox dev) or tlpe (AltPayNet production)
# MEETING_PAYMENT_PROVIDER=hitpay
# MEETING_PAYMENT_PROVIDER=tlpe
# Certified true copy base fee in PHP (online CTC uses AltPayNet TLPE).
# CTC_FEE_PHP=150
# AltPayNet TLPE. Docs: https://developers.tlpe.io/
# Two separate AltPayNet setups:
#   1) Notify/callback domain whitelist (your app URLs)
#   2) Server egress IP whitelist (EC2 outbound IP that calls api.tlpe.io)
# Local dev uses your home IP — will 401 until whitelisted or test on deployed staging.
#
# Notify webhook (register in AltPayNet portal, Notification URL):
#   Staging:    https://stg-qlegal.quanbyai.com/api/v1/payments/tlpe/webhook
#   Production: https://qlegal.quanbyit.com/api/v1/payments/tlpe/webhook
# TLPE POSTs JSON { "payload": "<JWT>" } with Authorization header (integrator token).
# Docs: https://developers.tlpe.io/post-notify-payment-result/
# TLPE_AUTHORIZATION=
# TLPE_SECRET=
# TLPE_API_URL=https://api.tlpe.io
# TLPE_PAYMENT_LINK_URL=   # Required for meeting + CTC payments (dynamic Easy Payment Link from AltPayNet)
# TLPE_PAYMENT_OPTION_CODE=
# TLPE_CALLBACK_URL=https://stg-qlegal.quanbyai.com/appointments

# Email — SMTP (Gmail) when RESEND_API_KEY is unset; otherwise Resend API
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your-gmail-app-password
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Quanby Legal
# Resend (optional; takes precedence over SMTP)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="qLegal <onboarding@resend.dev>"

# Appointments (E4): minutes before scheduled_at when “Start session” becomes true for confirmed bookings
# APPOINTMENT_SESSION_LEAD_MINUTES=15

# LiveKit (E5 notarial video). WebSocket namespace `/events`, room `session:<sessionRoomId>`.
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# Local-only: bypass profile KYC gates (booking, lobby, in_session) and session liveness (never use in prod).
# SESSION_DEV_RELAX_IDENTITY=true

# Dev/staging: allow POST /cert-exam/dev-perfect (auto-submit perfect score). Also works when NODE_ENV=development.
# CERT_EXAM_DEV_ASSIST=true

# Local-only: skip Hyperverge success requirement *for clients only* (ENP identity checks still enforced).
# Local-only: bypass profile KYC + liveness for *clients only* (ENP gates still enforced unless RELAX_IDENTITY).
# SESSION_DEV_RELAX_CLIENT_HYPERVERGE=true

# DOCONCHAIN (E6 QuickSign). Optional locally — without URL/key/secret, QuickSign uses mock DC UUIDs (no HTTP).
# API host only (no /api/v2 suffix): vault uses GET {host}/vault/items?user_type=ENTERPRISE_API&… per DocOnChain; token still POST …/api/v2/generate/token.
# DOCONCHAIN_API_URL=https://stg-api2.doconchain.com
# Vault HTTP (list/detail) is host-root GET /vault/items per DC docs; if you use …/api/v2 here, that suffix is stripped for vault calls only.
# DOCONCHAIN_APP_URL=https://stg-app.doconchain.com
# DOCONCHAIN_CLIENT_KEY=
# DOCONCHAIN_CLIENT_SECRET=
# When empty: token is obtained via POST /api/v2/generate/token using the ENP’s users.email (or org fallback as second try).
# DOCONCHAIN_ORG_EMAIL=stg_org@example.com
# Legacy alias for DOCONCHAIN_ORG_EMAIL (either works; ORG wins if both are set).
# DOCONCHAIN_EMAIL=stg_org@example.com
# When set: used as Bearer when /generate/token is skipped, or as fallback when token minting fails (e.g. DC staging Redis MISCONF 500).
# With only CLIENT_KEY/SECRET (no API_TOKEN), tokens are minted per ENP email via POST …/generate/token.
# Must belong to the same DocOnChain user that owns the project/vault row, or vault list/detail/download will return 401 (E_UNAUTHORIZED_ACCESS — wrong identity, not a random client bug).
# DOCONCHAIN_API_TOKEN=
# When true, always mint tokens via /generate/token (ignores API_TOKEN until minting fails, then falls back to API_TOKEN if set).
# DOCONCHAIN_FORCE_GENERATED_TOKEN=false
# When DocOnChain staging is broken (Redis MISCONF 500 on /generate/token), either set DOCONCHAIN_API_TOKEN above OR:
# DOCONCHAIN_DEV_MOCK_ON_FAILURE=true
# (development only — creates mock project UUIDs so QuickSign UI works; plot/sign in DC portal will not work until DC is healthy)
# DOC Verify (public /verify/document): optional override. Default: GET /api/v2/my/profile → data.uuid
# (same value as document verify API `user_uuid`). Not DOCONCHAIN_ORGANIZATION_UUID.
# DOCONCHAIN_VERIFY_USER_UUID=

# Supreme Court eNotarization API (E7). Cognito + POST /public-use/consolidated (+ optional PDF upload).
# SUPREME_COURT_API_URL=https://scenotarization-api.com
# SUPREME_COURT_AUTH_URL=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_P86ZTewxH
# SUPREME_COURT_CLIENT_ID=
# SUPREME_COURT_USERNAME=
# SUPREME_COURT_PASSWORD=
# SUPREME_COURT_NFN=NFN-2025-00017

# Contract AI (E9): Python FastAPI in apps/ai-service — traffic only from NestJS (same VPC). Web never calls Python directly.
# AI_SERVICE_BASE_URL=http://localhost:8010
# CONTRACT_AI_INTERNAL_TOKEN=change-me-long-random-shared-with-ai-service
# Base URL the AI container uses to POST /api/v1/internal/ai/resolve-download (Docker Desktop: http://host.docker.internal:3000)
# INTERNAL_API_BASE_URL=http://127.0.0.1:3000
# CONTRACT_AI_SIGNED_URL_TTL_SECONDS=120
# CONTRACT_AI_RATE_LIMIT_MAX=60
# CONTRACT_AI_RATE_LIMIT_WINDOW_MS=3600000
# Python service also needs XAI_API_KEY or OPENAI_API_KEY (see apps/ai-service/README.md)

# G1 hardening (rate limits + housekeeping crons — in-process per backend instance)
# VERIFY_DOCUMENT_RATE_LIMIT_PER_IP=20
# REGISTRY_SC_SYNC_RATE_LIMIT_MAX=60
# REGISTRY_SC_SYNC_RATE_LIMIT_WINDOW_MS=3600000
# FILE_UPLOAD_RATE_LIMIT_MAX=60
# FILE_UPLOAD_RATE_LIMIT_WINDOW_MS=3600000
# PAYMENT_INTENT_PENDING_MAX_AGE_MINUTES=1440

# Location verification (lobby gate). Reverse-geocodes coordinates via Google Maps and cross-checks the
# originating IP via ip-api.com + proxycheck.io. Required in production for the `Enter encrypted meeting`
# button to unlock; the join-token mint also re-checks for a recent allowed audit row.
# GOOGLE_MAPS_API_KEY=
# Optional but recommended: without it, VPN detection is advisory only (warned in prod).
# PROXYCHECK_API_KEY=
# When "true", LocationErrorDialog surfaces technical details (request ID, status codes, GPS accuracy).
# LOCATION_VERIFICATION_DEBUG=false
# Local-only escape hatch: skips the lobby location gate at the join-token mint step.
# SESSION_DEV_RELAX_LOCATION=true
# Max age (minutes) of a successful `session_location_verify` audit row to satisfy the token gate.
# SESSION_LOCATION_TOKEN_TTL_MIN=5
# ISO-2 country code required at the lobby (default PH).
# SESSION_REQUIRE_COUNTRY=PH
# Unused while lobby verification is PH-only (embassy radius not applied). Kept for a future flag.
# SESSION_EMBASSY_RADIUS_KM=1
# Max GPS accuracy (metres) accepted before returning `gps_accuracy_low`.
# SESSION_GPS_MAX_ACCURACY_M=200

# QLearn LMS integration (ENP onboarding certification course) — see docs/integrations/qlearn-qlegal-overview.md
# MUST be QLearn core API — NOT stg-qlegal.quanbyai.com, NOT http://backend:3000/api/v1
# LMS_INTEGRATION_BASE_URL=https://qlearn-core.quanbyit.com/api/v1
# LMS_INTEGRATION_API_KEY=
# Where the learner lands on QLearn after SSO (create-code redirectUri):
# LMS_INTEGRATION_COURSE_URL=https://qlearn.quanbyit.com/student/courses/view?id=crs_0bc482f1ea0b0eafb95d
# LMS_INTEGRATION_SSO_REDIRECT_URI=   # optional override; defaults to COURSE_URL
# QLegal page when learner returns from QLearn (staging: https://stg-qlegal.quanbyai.com/sso/callback):
# LMS_INTEGRATION_QLEGAL_RETURN_URI=http://localhost:3001/sso/callback
# LMS_INTEGRATION_SSO_HANDOFF_MODE=create_code   # or hmac (requires SHARED_SECRET + COURSE_URL)
# LMS_INTEGRATION_SSO_REDEEM_URL=https://qlearn.quanbyit.com/sso/callback
# LMS_INTEGRATION_SHARED_SECRET=   # must match QLearn QLEGAL_SSO_SHARED_SECRET (hmac mode)
# LMS_INTEGRATION_DEFAULT_CLASS_CODE=qlegal-12345
# LMS_INTEGRATION_DEFAULT_COURSE_ID=crs_0bc482f1ea0b0eafb95d
# LMS_INTEGRATION_ENROLLMENT_MODE=skip   # skip legacy course-enrollments API
# LMS_INTEGRATION_DEMO_EMAIL=   # stub mode only
# LMS_INTEGRATION_DEMO_PASSWORD=

